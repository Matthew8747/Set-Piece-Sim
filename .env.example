# ============================================================================
# Restart Lab - environment configuration template
# Copy to .env for local development:   cp .env.example .env
# NEVER commit .env. Production injects real environment variables via the
# hosting platform's secret store (Fly.io `fly secrets` / Vercel env), not files.
# ============================================================================

# --- Backend (FastAPI). All variables use the RESTART_ prefix. ---
RESTART_APP_ENV=dev            # dev | test | prod
RESTART_DEBUG=true
# Allowed browser origins, JSON list syntax:
RESTART_CORS_ORIGINS=["http://localhost:3000"]

# Storage + jobs are server-free by default: with these UNSET the API uses a
# local SQLite store + an in-process job queue, so it boots with no external
# services (the demo path). Set them to scale out to Postgres + Arq/Redis — the
# same Protocols, drop-in (ADR-007 d1/d2). Values below match
# infra/docker-compose.yml and are LOCAL-DEV ONLY:
# RESTART_DATABASE_URL=postgresql+psycopg://restart:restart@localhost:5432/restart
# RESTART_REDIS_URL=redis://localhost:6379/0

# Data locations (real settings; defaults shown). The /optimize surface works
# out of the box from the committed optimization_studies/. The /scenarios squads
# + xG come from data/marts, built locally by the StatsBomb ETL (open data,
# derived locally — not redistributed; see docs/etl-runbook.md):
# RESTART_DATA_DIR=data
# RESTART_STUDIES_DIR=optimization_studies

# API key for mutating endpoints (Phase 6+). Generate, don't invent:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# RESTART_API_KEY=

# --- Frontend (Next.js). Browser-visible vars MUST use NEXT_PUBLIC_. ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
