# --- Python ---
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
*.egg-info/

# --- Node / Next.js ---
node_modules/
.next/
coverage/
*.tsbuildinfo
next-env.d.ts

# --- Environment & secrets (never commit real env files) ---
.env
.env.*
!.env.example

# --- Data lake: rebuildable from sources via restart-etl; structure kept via .gitkeep ---
data/raw/*
data/staging/*
data/marts/*
!data/raw/.gitkeep
!data/staging/.gitkeep
!data/marts/.gitkeep
# Local-only training artifacts under data/ (MLflow store, stale model dir).
data/mlflow.db
data/mlflow/
data/models/

# --- ML artifacts: heavy binaries stay out of git; the small derived xG
#     coefficient bundle (JSON) IS committed so the engine ships a working model
#     and CI can integration-test it (raw data is git-ignored, so CI can't retrain).
mlruns/
models/*
!models/*.json

# --- Local tooling artifacts (Claude Code plugins etc.) ---
ruvector.db
graphify-out/

# --- OS / editors ---
.DS_Store
Thumbs.db
.idea/
.vscode/
