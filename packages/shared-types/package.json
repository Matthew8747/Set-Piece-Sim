{
  "name": "@restart/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript mirrors of the backend API contract. Source-shipped (no build step); the frontend transpiles it via next.config transpilePackages.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "gen": "openapi-typescript ../../apps/backend/openapi.json -o src/generated.ts --default-non-nullable false"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.7.2"
  }
}
