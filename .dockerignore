# Keep the build context small + the image clean. The backend image needs the
# Python workspace only — not the JS toolchain, build outputs, data lake, or VCS.
.git
.github
node_modules
**/node_modules
.next
**/.next
apps/frontend
packages/pitch-kit
packages/shared-types
.venv
**/.venv
**/__pycache__
**/*.pyc
.pytest_cache
**/.pytest_cache
.mypy_cache
**/.mypy_cache
.ruff_cache
htmlcov
# data/marts is intentionally NOT ignored: the small squad + xG marts (~2 MB)
# are baked into the image so /scenarios works with no volume (simplest deploy).
data/raw
data/staging
test-results
playwright-report
*.log
.env
